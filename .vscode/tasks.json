{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "start:client",
      "type": "shell",
      "command": "npm run start:client",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(?!)",
          "message": 0
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "^webpack\\s+\\d+\\.\\d+\\.\\d+\\s+compiled successfully"
        }
      }
    },
    {
      "label": "start:server",
      "type": "shell",
      "command": "npm run start:server",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(?!)",
          "message": 0
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "^Server is listening on port\\s+\\d+"
        }
      }
    }
  ]
}
